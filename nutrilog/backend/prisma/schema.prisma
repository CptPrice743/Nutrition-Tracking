generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id           String   @id @default(uuid())
  firebaseUid  String   @unique @map("firebase_uid")
  email        String   @unique
  displayName  String?  @map("display_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  dailyLogs       DailyLog[]
  habits          Habit[]
  habitLogs       HabitLog[]
  dashboardLayout DashboardLayout?

  @@map("users")
}

model DailyLog {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  date              DateTime @db.Date
  weightKg          Decimal? @map("weight_kg") @db.Decimal(5, 2)
  caloriesConsumed  Int?     @map("calories_consumed")
  proteinG          Int?     @map("protein_g")
  carbsG            Int?     @map("carbs_g")
  fatTotalG         Int?     @map("fat_total_g")
  fatSaturatedG     Int?     @map("fat_saturated_g")
  fatUnsaturatedG   Int?     @map("fat_unsaturated_g")
  fatTransG         Decimal? @map("fat_trans_g") @db.Decimal(4, 2)
  magnesiumMg       Int?     @map("magnesium_mg")
  ironMg            Decimal? @map("iron_mg") @db.Decimal(5, 2)
  zincMg            Decimal? @map("zinc_mg") @db.Decimal(5, 2)
  waterLitres       Decimal? @map("water_litres") @db.Decimal(4, 2)
  dayType           String?  @map("day_type")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitLogs HabitLog[]

  @@unique([userId, date])
  @@map("daily_logs")
}

model Habit {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  name             String
  habitType        String   @map("habit_type")
  unitLabel        String?  @map("unit_label")
  frequencyType    String   @map("frequency_type")
  frequencyX       Int?     @map("frequency_x")
  frequencyY       Int?     @map("frequency_y")
  targetValue      Decimal? @map("target_value")
  targetDirection  String?  @map("target_direction")
  isCalorieBurning Boolean  @default(false) @map("is_calorie_burning")
  calorieUnit      Decimal? @map("calorie_unit")
  calorieKcal      Decimal? @map("calorie_kcal")
  isActive         Boolean  @default(true) @map("is_active")
  displayOrder     Int      @default(0) @map("display_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitLogs HabitLog[]

  @@map("habits")
}

model HabitLog {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  habitId        String   @map("habit_id")
  dailyLogId     String?  @map("daily_log_id")
  logDate        DateTime @db.Date @map("log_date")
  value          Decimal?
  caloriesBurned Decimal? @map("calories_burned")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit    Habit     @relation(fields: [habitId], references: [id], onDelete: Cascade)
  dailyLog DailyLog? @relation(fields: [dailyLogId], references: [id], onDelete: SetNull)

  @@unique([userId, habitId, logDate])
  @@map("habit_logs")
}

model DashboardLayout {
  id         String   @id @default(uuid())
  userId     String   @unique @map("user_id")
  layoutJson Json     @map("layout_json")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dashboard_layouts")
}
